# VS Code 配置
.vscode

# 版本控制
.gitignore
**/.git
**/.svn
**/.hg
**/CVS

# 系统文件
**/.DS_Store
**/Thumbs.db

# 测试
.vscode-test

# 明确排除 devDependencies（不整体排除 node_modules/，
# 以确保 axios 及其所有传递依赖被正确打包）
node_modules/.bin/
node_modules/typescript/
node_modules/@types/
node_modules/undici-types/

# TypeScript 源文件（已编译到 out/）
src
tsconfig.json
**/*.ts

# Sourcemap（调试用，发布时排除）
**/*.map

# 旧的构建产物
*.vsix

# 本地开发数据（不应随扩展发布）
.OpenVibe/

# 文档与图片
imgs
logo.png

# 依赖锁定文件
package-lock.json
